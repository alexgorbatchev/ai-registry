{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "formatter": false,

  "plugin": [
    "@tarquinen/opencode-dcp@3.1.9",
    // Vendored as a repo workspace and loaded from source so root bun install satisfies runtime imports.
    "file://{{repo_root}}/vendor/opencode-context-inspector/src/index.ts"
  ],

  "instructions": [
    "AGENTS.md",
    "{{repo_root}}/harnesses/.common/system.md",
    "{{repo_root}}/harnesses/.common/karpathy-skills.md"
  ],

  "mcp": {
    "graymatter": {
      "type": "local",
      "command": ["graymatter", "mcp", "serve"],
      "enabled": true
    }
  },

  "permission": {
    "external_directory": {
      "{{repo_root}}/**": "allow"
    },
    "bash": {
      "git checkout *": "ask",
      "git reset *": "ask",
    }
  },

  "disabled_providers": [],
  "experimental": {
    "mcp_timeout": 420000
  },
}
