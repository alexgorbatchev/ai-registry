{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "formatter": false,
  "default_agent": "developer",

  "agent": {
    "build": {
      "disable": true,
    },
  },

    //"@tarquinen/opencode-dcp@3.1.9",
  "plugin": [
    // Vendored as a repo workspace and loaded from source so root bun install satisfies runtime imports.
    "file://{{repo_root}}/vendor/opencode-context-inspector/src/index.ts"
  ],

  "instructions": [
    "{{repo_root}}/system/system.md",
  ],

  "mcp": {
    // "graymatter": {
    //   "type": "local",
    //   "command": ["graymatter", "mcp", "serve"],
    //   "enabled": true
    // }
  },

  "permission": {
    "question": "allow",

    "external_directory": {
      "{{repo_root}}/**": "allow",
      "~/**": "allow",
    },
    "bash": {
      "git checkout *": "ask",
      "git reset *": "ask",
    }
  },

  "disabled_providers": [],
  "experimental": {
    "mcp_timeout": 420000
  },
}
