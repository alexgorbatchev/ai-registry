{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "formatter": false,

  "plugin": [
    "@tarquinen/opencode-dcp@3.1.9",
    // Unpublished package: install directly from Git and pin the commit.
    "git+https://github.com/gscalzo/opencode-context-inspector.git#9f725fa524442be53951c6961ce4f036af5eb0fe"
  ],

  "instructions": [
    "AGENTS.md",
    "{{repo_root}}/harnesses/.common/system.md",
    "{{repo_root}}/harnesses/.common/karpathy-skills.md"
  ],

  "mcp": {
    "graymatter": {
      "type": "local",
      "command": ["graymatter", "mcp", "serve"],
      "enabled": true
    }
  },

  "permission": {
    "external_directory": {
      "{{repo_root}}/**": "allow"
    },
    "bash": {
      "git checkout *": "ask",
      "git reset *": "ask",
    }
  },

  "disabled_providers": [],
  "experimental": {
    "mcp_timeout": 420000
  },
}
