{
  "name": "@alexgorbatchev/ai-registry",
  "version": "1.0.0",
  "description": "Canonical AI skills, commands, and harness profiles",
  "private": true,
  "workspaces": [
    "vendor/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run typecheck && bun run scripts/build.ts",
    "bootstrap": "bun run scripts/bootstrap.ts",
    "bootstrap:smoke": "bun run scripts/smoke-bootstrap.ts",
    "prepare": "bun run scripts/installGitHooks.ts",
    "typecheck": "tsgo -p tsconfig.json",
    "sync:opencode-docs": "bun run harnesses/opencode/scripts/sync-docs.ts",
    "skills:add": "bun run scripts/addVendoredSkill.ts",
    "skills:list": "npx skills add . --list",
    "skills:update": "bun run scripts/updateVendoredSkills.ts && bun run build"
  },
  "dependencies": {
    "@alexgorbatchev/dedent-string": "^1.0.1",
    "@types/ignore-walk": "^4.0.3",
    "globby": "^16.1.1",
    "ignore-walk": "^8.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.12",
    "@typescript/native-preview": "^7.0.0-dev.20260422.1"
  }
}
