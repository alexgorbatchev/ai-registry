#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"

while [ -L "$SOURCE_PATH" ]; do
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  case "$SOURCE_PATH" in
    /*) ;;
    *) SOURCE_PATH="$SCRIPT_DIR/$SOURCE_PATH" ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
REPO_ROOT="$(dirname -- "$SCRIPT_DIR")"

exec env OPENCODE_CONVERSATION_EXTRACT_COMMAND="air-opencode-conversation-extract" \
  bun "$REPO_ROOT/harnesses/opencode/skills/opencode-conversation-analysis/scripts/extract.ts" "$@"
